generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Пользователи ────────────────────────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at")
  name         String
  email        String   @unique
  password     String
  role         String   @default("client")
  address      String   @default("")
  phone        String
  orders       Order[]

  @@map("users")
}

// ─── Скидки/надбавки ─────────────────────────────────────────────────────────
model Discount {
  id          Int     @id @default(autoincrement())
  percent     Float
  description String
  orders      Order[]

  @@map("discounts")
}

// ─── Размеры холста ───────────────────────────────────────────────────────────
model CanvasSize {
  id     Int      @id @default(autoincrement())
  size   String   @unique
  prices Price[]

  @@map("canvas_sizes")
}

// ─── Виды оформления ──────────────────────────────────────────────────────────
model DesignType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  prices      Price[]

  @@map("design_types")
}

// ─── Техники исполнения ───────────────────────────────────────────────────────
model Technique {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  prices    Price[]

  @@map("techniques")
}

// ─── Сюжеты ───────────────────────────────────────────────────────────────────
model Subject {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  prices Price[]

  @@map("subjects")
}

// ─── Прайс-лист ───────────────────────────────────────────────────────────────
model Price {
  id           Int        @id @default(autoincrement())
  canvasSizeId Int        @map("canvas_size_id")
  designTypeId Int        @map("design_type_id")
  techniqueId  Int        @map("technique_id")
  subjectId    Int        @map("subject_id")
  price        Float

  canvasSize   CanvasSize @relation(fields: [canvasSizeId], references: [id])
  designType   DesignType @relation(fields: [designTypeId], references: [id])
  technique    Technique  @relation(fields: [techniqueId], references: [id])
  subject      Subject    @relation(fields: [subjectId], references: [id])

  orderItems   OrderItem[]

  @@unique([canvasSizeId, designTypeId, techniqueId, subjectId])
  @@map("prices")
}

// ─── Заказы ───────────────────────────────────────────────────────────────────
model Order {
  id           Int         @id @default(autoincrement())
  userId       Int?        @map("user_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  deadline     String      @default("")
  issueDate    String      @default("") @map("issue_date")
  discountId   Int?        @map("discount_id")
  totalPrice   Float       @map("total_price")
  prepayment   Float       @default(0)
  status       String      @default("new")
  photoPaths   String      @default("[]") @map("photo_paths")
  comments     String      @default("")

  user         User?       @relation(fields: [userId], references: [id])
  discount     Discount?   @relation(fields: [discountId], references: [id])
  items        OrderItem[]

  @@map("orders")
}

// ─── Картины в заказе ─────────────────────────────────────────────────────────
model OrderItem {
  id          Int    @id @default(autoincrement())
  orderId     Int    @map("order_id")
  priceId     Int    @map("price_id")
  quantity    Int    @default(1)
  pricePerUnit Float @map("price_per_unit")
  total       Float

  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  price       Price  @relation(fields: [priceId], references: [id])

  @@map("order_items")
}

// ─── Администраторы ───────────────────────────────────────────────────────────
model Admin {
  id           Int    @id @default(autoincrement())
  login        String @unique
  passwordHash String @map("password_hash")

  @@map("admins")
}
