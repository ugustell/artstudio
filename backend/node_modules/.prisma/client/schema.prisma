generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at")
  name         String
  phone        String
  email        String   @unique
  address      String   @default("")
  passwordHash String   @map("password_hash")
  orders       Order[]

  @@map("users")
}

model Order {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now()) @map("created_at")
  clientName       String   @map("client_name")
  phone            String
  email            String
  size             String
  format           String
  design           String
  material         String   @default("")
  coating          String   @default("")
  status           String   @default("new")
  quantity         Int      @default(1)
  deadline         String   @default("") @map("deadline")
  basePrice        Float    @default(0) @map("base_price")
  discountPercent  Float    @default(0) @map("discount_percent")
  discountReason   String   @default("") @map("discount_reason")
  surchargePercent Float    @default(0) @map("surcharge_percent")
  surchargeReason  String   @default("") @map("surcharge_reason")
  totalPrice       Float    @map("total_price")
  prepayment       Float    @default(0) @map("prepayment")
  issueDate        String   @default("") @map("issue_date")
  photoPaths       String   @default("[]") @map("photo_paths")
  comments         String   @default("")
  userId           Int?     @map("user_id")
  user             User?    @relation(fields: [userId], references: [id])

  @@map("orders")
}

model Price {
  id       Int    @id @default(autoincrement())
  size     String @unique
  price    Float
  category String @default("standard")

  @@map("prices")
}

model Admin {
  id           Int    @id @default(autoincrement())
  login        String @unique
  passwordHash String @map("password_hash")

  @@map("admins")
}
